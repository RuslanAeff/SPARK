{
  "expo": {
    "name": "S.P.A.R.K",
    "slug": "spark-finance",
    "version": "2.2.0",
    "orientation": "portrait",
    "icon": "./assets/spark-icon.png",
    "userInterfaceStyle": "dark",
    "scheme": "spark",
    "splash": {
      "image": "./assets/spark-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#0D0D0F"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.spark.finance"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#0D0D0F",
        "foregroundImage": "./assets/spark-icon.png"
      },
      "package": "com.spark.finance",
      "versionCode": 4,
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.POST_NOTIFICATIONS"
      ]
    },
    "web": {
      "favicon": "./assets/spark-icon.png",
      "bundler": "metro"
    },
    "plugins": [
      "expo-router",
      "expo-font",
      "expo-sqlite",
      [
        "expo-camera",
        {
          "cameraPermission": "S.P.A.R.K. fiş taramak için kameranıza erişmek istiyor."
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "S.P.A.R.K. logo ve fiş yüklemek için galerinize erişmek istiyor."
        }
      ],
      "expo-secure-store",
      "expo-notifications",
      "expo-sharing"
    ],
    "extra": {
      "router": {},
      "eas": {}
    },
    "owner": "ruslanaeff0"
  }
}
